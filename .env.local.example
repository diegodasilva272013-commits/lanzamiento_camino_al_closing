# Link del Meet que se envía a los registrados
MEET_LINK=https://meet.google.com/abc-defg-hij

# Configuración SMTP (ejemplo Gmail con App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-app-password-de-16-caracteres
MAIL_FROM="Camino al Closing <tu-correo@gmail.com>"

# Google Sheets (via Apps Script Web App)
# 1) Creá una hoja de cálculo en Google Sheets.
# 2) Menú: Extensiones > Apps Script y pegá el contenido de scripts/google-sheets.gs.
# 3) Reemplazá SHEET_ID en el script con el id de tu hoja.
# 4) Implementar > Nueva implementación > Tipo: Aplicación web.
#    - Ejecutar como: tú mismo.
#    - Quién tiene acceso: cualquiera (con el enlace).
# 5) Copiá la URL del Web App acá:
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/XXXXXXXXX/exec
# Opcional: token compartido para validar requests en Apps Script.
GOOGLE_SHEETS_SECRET=

# === WhatsApp vía Twilio ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Formato: "whatsapp:+14155238886" (sandbox) o tu número aprobado
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Content SID de la plantilla WhatsApp aprobada (opcional). Si está vacío, se envía mensaje libre
# (sólo funciona dentro de la ventana de 24h posterior al primer mensaje del contacto).
# Variables esperadas en la plantilla: {{1}} = nombre, {{2}} = link del Meet.
TWILIO_CONTENT_SID=
# Template SID por defecto para campañas de difusión desde /difusion
TWILIO_BROADCAST_TEMPLATE_SID=
# URL de la landing que se inserta como variable {{2}} en la plantilla de difusión
LANDING_URL=https://lanzamiento-camino-al-closing.vercel.app/lanzamiento
# Código de país por defecto si el usuario no lo pone (ej: 54 = Argentina)
DEFAULT_COUNTRY_CODE=54

# Clave simple para proteger el panel /difusion
ADMIN_PASSWORD=
